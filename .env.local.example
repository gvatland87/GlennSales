# Kopier denne filen til .env.local og fyll inn verdiene fra ditt Supabase-prosjekt.
# Finn dem under: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://DITT_PROSJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din_anon_key_her

# Sett NEXT_PUBLIC_APP_URL til din Vercel-domene i produksjon
NEXT_PUBLIC_APP_URL=http://localhost:3001
